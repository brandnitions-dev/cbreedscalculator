generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum ProductType {
  BALM
  CLEANER
  EXFOLIATOR
  SOAP
  TREATMENT_OIL
}

enum IngredientPotency {
  mild
  moderate
  strong
}

// Tallow Balm: filter pools by skin concern (LA/linoleic-leaning vs ALA/anti-inflammatory-leaning)
enum BalmDermalFocus {
  universal
  dry
  oily
}

enum IngredientUsageFocus {
  universal
  face
  body
  lips
  eyes
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  formulas     Formula[]
}

model Ingredient {
  id        String  @id @default(cuid())
  // Stable identifier used throughout calculators (matches prior hardcoded ids)
  slug      String  @unique
  name      String
  desc      String

  // Cosmetic/formula metadata (optional per group)
  color     String?
  potency   IngredientPotency?
  maxPct    Float?
  warn      Boolean @default(false)
  // Only active ingredients are exposed to public formula builders.
  active    Boolean @default(false)

  // Rich content carried over from hardcoded data
  benefits  Json    @default("{}")
  tips      Json    @default("{\"low\":\"\",\"mid\":\"\",\"high\":\"\"}")

  // For soap oils/additives or any future group-specific fields
  meta      Json    @default("{}")

  // Tallow Balm: which skin profile this row is most relevant to (universal = show in all)
  balmDermalFocus BalmDermalFocus @default(universal)
  // Formula usage surface (universal = show in face and body modes)
  usageFocus IngredientUsageFocus @default(universal)

  groups    IngredientGroupAssignment[]
  products  IngredientProductAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IngredientGroup {
  id        String  @id @default(cuid())
  // Machine key e.g. carriers_a, actives_b, essential_oils, soap_oils
  key       String  @unique
  label     String
  sortOrder Int     @default(0)

  ingredients IngredientGroupAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IngredientGroupAssignment {
  id           String         @id @default(cuid())
  ingredientId String
  groupId      String
  sortOrder    Int            @default(0)

  ingredient Ingredient     @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  group      IngredientGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([ingredientId, groupId])
  @@index([groupId])
  @@index([ingredientId])
}

model IngredientProductAssignment {
  id           String      @id @default(cuid())
  ingredientId String
  productType  ProductType

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([ingredientId, productType])
  @@index([productType])
  @@index([ingredientId])
}

model Formula {
  id          String      @id @default(cuid())
  name        String
  productType ProductType
  mode        String?     // face | body (for balm/exfoliator)
  batchSize   Float       @default(100)
  ingredients Json        // full ingredient pool snapshot
  eoBlend     Json?       // essential oil blend snapshot
  soapData    Json?       // lye, water, superfat, cure data
  // User labels, e.g. "dry skin", "body", "summer"
  tags        Json         @default("[]")
  notes       String?
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  batches     BatchLog[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
}

model BatchLog {
  id        String   @id @default(cuid())
  formulaId String
  formula   Formula  @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  batchSize Float
  notes     String?
  createdAt DateTime @default(now())

  @@index([formulaId])
}
