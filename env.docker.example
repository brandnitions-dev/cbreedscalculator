# Copy to /opt/mosskynlab/.env on the VPS (never commit real values).

POSTGRES_PASSWORD=change-me-strong-password

# Inside Docker, hostname is the compose service name `db`:
DATABASE_URL=postgresql://mosskynlab:change-me-strong-password@db:5432/mosskynlab

NEXTAUTH_URL=https://mosskynlab.brandnitions.agency
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
